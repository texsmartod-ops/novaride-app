PORT=4174

# Twilio SMS settings
# Fill these values from your Twilio Console.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+12345678900

# TurboSMS settings for Ukraine
# Recommended for Ukrainian phone numbers.
TURBOSMS_TOKEN=your_turbosms_http_api_token
TURBOSMS_SENDER=TurboSMS

# Email verification codes through Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=NovaRide <onboarding@resend.dev>

# Mapbox public token for the live map
MAPBOX_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxx

# Social login
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
APPLE_CLIENT_ID=ua.novaride.web

# Keep development while testing locally. Use production on a real server.
NODE_ENV=development
